# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# RESEND_API_KEY: The API key for Resend email sending service.
RESEND_API_KEY=""

# RESEND_FROM_EMAIL: The sender's email address in Resend (defaults to onboarding@resend.dev).
RESEND_FROM_EMAIL=""

# RESEND_TO_EMAIL: The destination email address for contact form submissions (defaults to webox.info@proton.me).
RESEND_TO_EMAIL=""

# ADMIN_PASSWORD: Password required to access the admin dashboard at /admin/...
ADMIN_PASSWORD="webox2026"

