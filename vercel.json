{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|logo-192.png|logo-512.png|logo.jpg|logo.png|manifest.json|sitemap.xml|sw.js|favicon.ico|googlea34f4f888ccac059.html).*)",
      "destination": "/index.html"
    }
  ]
}
