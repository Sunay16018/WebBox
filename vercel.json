{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/logo-192.png", "destination": "/logo-192.png" },
    { "source": "/logo-512.png", "destination": "/logo-512.png" },
    { "source": "/logo.jpg", "destination": "/logo.jpg" },
    { "source": "/logo.png", "destination": "/logo.png" },
    { "source": "/manifest.json", "destination": "/manifest.json" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/sw.js", "destination": "/sw.js" },
    { "source": "/favicon.ico", "destination": "/favicon.ico" },
    { "source": "/googlea34f4f888ccac059.html", "destination": "/googlea34f4f888ccac059.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
